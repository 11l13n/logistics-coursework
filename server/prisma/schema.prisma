generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DISPATCHER
  DRIVER
}

enum DriverStatus {
  AVAILABLE
  BUSY
  INACTIVE
}

enum VehicleStatus {
  AVAILABLE
  BUSY
  REPAIR
  INACTIVE
}

enum CargoRequestStatus {
  NEW
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WaybillStatus {
  CREATED
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(DISPATCHER)
  driver       Driver?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Driver {
  id              Int          @id @default(autoincrement())
  userId          Int?         @unique
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName        String
  phone           String
  licenseNumber   String       @unique
  licenseCategory String
  status          DriverStatus @default(AVAILABLE)
  routes          Route[]
}

model Vehicle {
  id                       Int           @id @default(autoincrement())
  brand                    String
  model                    String
  plateNumber              String        @unique
  capacityKg               Int
  fuelConsumptionPer100Km  Float
  status                   VehicleStatus @default(AVAILABLE)
  routes                   Route[]
}

model Client {
  id            Int            @id @default(autoincrement())
  name          String
  contactPerson String
  phone         String
  email         String
  address       String
  cargoRequests CargoRequest[]
}

model CargoRequest {
  id                  Int                @id @default(autoincrement())
  clientId            Int
  client              Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cargoName           String
  weightKg            Int
  volume              Float
  pickupAddress       String
  deliveryAddress     String
  desiredDeliveryDate DateTime
  status              CargoRequestStatus @default(NEW)
  createdAt           DateTime           @default(now())
  archivedAt          DateTime?
  deliveryPoints      CargoDeliveryPoint[]
  routes              Route[]
}

model CargoDeliveryPoint {
  id             Int          @id @default(autoincrement())
  cargoRequestId Int
  cargoRequest   CargoRequest @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  address        String
  latitude       Float
  longitude      Float
  orderNumber    Int
}

model Route {
  id              Int          @id @default(autoincrement())
  cargoRequestId  Int
  cargoRequest    CargoRequest @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  driverId        Int
  driver          Driver       @relation(fields: [driverId], references: [id])
  vehicleId       Int
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id])
  startAddress    String
  endAddress      String
  distanceKm      Float
  estimatedDuration String
  plannedDate     DateTime
  status          RouteStatus  @default(PLANNED)
  createdAt       DateTime     @default(now())
  archivedAt      DateTime?
  waypoints       Waypoint[]
  waybill         Waybill?
}

model Waypoint {
  id          Int    @id @default(autoincrement())
  routeId     Int
  route       Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  address     String
  latitude    Float
  longitude   Float
  orderNumber Int
}

model Waybill {
  id            Int           @id @default(autoincrement())
  routeId       Int           @unique
  route         Route         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  number        String        @unique
  issueDate     DateTime      @default(now())
  departureTime DateTime?
  returnTime    DateTime?
  startMileage  Int?
  endMileage    Int?
  plannedFuel   Float
  actualFuel    Float?
  status        WaybillStatus @default(CREATED)
  archivedAt    DateTime?
}
